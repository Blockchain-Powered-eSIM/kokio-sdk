# Copy to `.env` and fill in to run the opt-in live integration tests:
#   npm run test:integration
#
# `.env` is git-ignored. Without these set, `npm run test:integration` skips
# cleanly (and `npm test` never touches the network).

# Base Sepolia (chain 84532) JSON-RPC endpoint. Any provider works
# (Alchemy/Infura/QuickNode) or the public https://sepolia.base.org.
# Only read access is exercised — no funds or private key required.
BASE_SEPOLIA_RPC_URL=

# Optional future second target for the read-only parity tier.
# SEPOLIA_RPC_URL=

# --- Write / UserOp scenario tier (local Base Sepolia fork) ---
# `npm run test:integration:fork` runs EOA-admin and software-P256 userOp
# scenarios against a local `anvil` fork of Base Sepolia. It needs NO keys and NO
# Pimlico — the admin is impersonated and userOps go straight to
# EntryPoint.handleOps. Requirements: INTEGRATION=1 and Foundry (`anvil`) on PATH.
# See tests/integration/README.md. The fork reuses BASE_SEPOLIA_RPC_URL above as
# its upstream (falls back to the public endpoint), so nothing extra is required.
#
# ANVIL_BIN — optional path to a specific `anvil` binary, when a newer Foundry
# lives outside PATH (e.g. ~/.foundry/bin/anvil).
# ANVIL_BIN=
